# Wolf Industries - DarkWeb Monitor Configuration

# Anthropic Claude API key (required for AI analysis & reports)
ANTHROPIC_API_KEY=sk-ant-...

# Have I Been Pwned API key (optional, for email breach checks)
HIBP_API_KEY=

# Tor SOCKS5 proxy (docker-compose overrides these automatically)
TOR_PROXY_HOST=127.0.0.1
TOR_PROXY_PORT=9050

# App settings
APP_SECRET_KEY=change-this-to-a-random-secret
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production

# Database
DATABASE_URL=sqlite:///./wolfwatch.db

# Default scan interval in hours
DEFAULT_SCAN_INTERVAL_HOURS=6

# Max concurrent crawl tasks
MAX_CONCURRENT_CRAWLS=3

# Company identity (used for context in AI analysis)
COMPANY_NAME=Wolf Industries
COMPANY_DOMAINS=wolfindustries.com,wolfind.com

# ─── Docker service URLs (auto-set by docker-compose) ─────────────────────
# Only set these manually if running outside Docker
# REDIS_URL=redis://localhost:6379/0
# SPIDERFOOT_URL=http://localhost:5001
# SEARXNG_URL=http://localhost:8888

# ─── Free API keys (optional, for higher rate limits) ─────────────────────
# GreyNoise community key — free at https://viz.greynoise.io/signup
GREYNOISE_API_KEY=

# Phishtank app key — free at https://phishtank.org/api_register.php
PHISHTANK_API_KEY=
